{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "prisma generate && tsc",
    "start": "prisma generate && node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "dev:docker": "prisma generate && tsx watch src/server.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:empty": "prisma migrate dev --create-only",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "db:auth-bootstrap": "docker exec -i supabase_db_seng513-202601-pg-40 psql -U postgres -d postgres < sql/supabase-auth-bootstrap.sql",
    "db:seed": "docker exec -i supabase_db_seng513-202601-pg-40 psql -U postgres -d postgres < sql/seed.sql",
    "db:reset": "prisma migrate reset --force && npm run db:auth-bootstrap && npm run db:seed",
    "db:setup": "npm run prisma:migrate && npm run db:auth-bootstrap",
    "db:setup-prod": "prisma migrate deploy && npm run db:auth-bootstrap",
    "typecheck": "prisma generate && tsc -p tsconfig.json --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@azure/communication-email": "^1.1.0",
    "@azure-rest/ai-document-intelligence": "^1.1.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@supabase/supabase-js": "^2.98.0",
    "@volunteerly/shared": "^0.0.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "pg": "^8.19.0",
    "supabase": "^2.76.17",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@azure-rest/ai-document-intelligence": "^1.1.0",
    "@prisma/client": "^7.4.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.3.5",
    "prisma": "^7.4.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
