{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "prisma generate && tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "dev:docker": "prisma generate && tsx watch src/server.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:empty": "prisma migrate dev --create-only",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "db:auth-bootstrap": "psql postgresql://postgres:postgres@127.0.0.1:54322/postgres -f sql/supabase-auth-bootstrap.sql",
    "db:setup": "npm run prisma:migrate && npm run db:auth-bootstrap",
    "db:setup-prod": "prisma migrate deploy && npm run db:auth-bootstrap",
    "typecheck": "prisma generate && tsc -p tsconfig.json --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@supabase/supabase-js": "^2.98.0",
    "@volunteerly/shared": "^0.0.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "pg": "^8.19.0",
    "zod": "^4.3.6",
    "supabase": "^2.76.17"
  },
  "devDependencies": {
    "@prisma/client": "^7.4.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.5",
    "prisma": "^7.4.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
