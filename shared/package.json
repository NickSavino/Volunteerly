{
    "name": "@volunteerly/shared",
    "version": "0.0.1",
    "description": "Shared types and schemas for Volunteerly",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "types": "./src/index.ts",
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "src"
    ],
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "clean": "rimraf dist",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "test": "jest --config jest.config.cjs"
    },
    "author": "",
    "license": "ISC",
    "dependencies": {
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/jest": "^30.0.0",
        "@types/node": "^25.3.3",
        "jest": "^30.3.0",
        "rimraf": "^6.1.3",
        "ts-jest": "^29.4.9",
        "typescript": "^5.9.3"
    }
}
